  exchangeRate     Decimal            @default(1) @db.Decimal(20, 8)
  baseAmount       Decimal            @db.Decimal(20, 4)
  transferDate     DateTime
  reference        String?
  swiftRef         String?
  status           BankTransferStatus @default(PENDING)
  fileUrl          String?
  completedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  payment         Payment     @relation(fields: [paymentId], references: [id])
  fromBankAccount BankAccount @relation(fields: [fromBankAccountId], references: [id])

  @@index([status, transferDate])
  @@map("bank_transfers")
}

model PaymentDeclaration {
  id              String   @id @default(cuid())
  paymentId       String
  declarationDate DateTime
  signatoryId     String
  amount          Decimal  @db.Decimal(20, 4)
  currency        String   @default("USD")
  purpose         String
  notes           String?
  fileUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@map("payment_declarations")
}

// ============================================================
// DOMAIN 6: WORKFLOW (8 tables)
// ============================================================

model WorkflowTemplate {
  id           String   @id @default(cuid())
  name         String   @unique
  documentType String
  description  String?
  isActive     Boolean  @default(true)
  version      Int      @default(1)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  steps     WorkflowStep[]
  instances WorkflowInstance[]

  @@index([documentType, isActive])
  @@map("workflow_templates")
}

model WorkflowStep {
  id               String   @id @default(cuid())
  templateId       String
  stepNumber       Int
  name             String
  approverRoleId   String?
  approverUserId   String?
  isParallel       Boolean  @default(false)
  isMandatory      Boolean  @default(true)
  slaHours         Int      @default(48)
  escalationHours  Int?
  escalationRoleId String?
  allowDelegate    Boolean  @default(true)
  allowReturn      Boolean  @default(true)
  allowReject      Boolean  @default(true)
  conditions       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  template       WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  approverRole   Role?            @relation("ApproverRole", fields: [approverRoleId], references: [id])
  escalationRole Role?            @relation("EscalationRole", fields: [escalationRoleId], references: [id])

  @@unique([templateId, stepNumber])
  @@index([templateId])
  @@map("workflow_steps")
}

model WorkflowInstance {
  id                String         @id @default(cuid())
  templateId        String
  documentType      String
  documentId        String
  currentStepNumber Int            @default(1)
  status            WorkflowStatus @default(PENDING)
  startedAt         DateTime       @default(now())
  completedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  template      WorkflowTemplate      @relation(fields: [templateId], references: [id])
  steps         WorkflowInstanceStep[]
  actions       WorkflowActionLog[]
  escalations   WorkflowEscalation[]
  // Document back-relations
  grantAmendments    GrantAmendment[]
  grantExtensions    GrantExtension[]
  annualPlans        AnnualProcurementPlan[]
  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders     PurchaseOrder[]
  goodsReceipts      GoodsReceipt[]
  contracts          Contract[]
  vendorInvoices     VendorInvoice[]
  pafForms           PurchaseAnalysisForm[]
  paymentRequests    PaymentRequest[]
  paymentVouchers    PaymentVoucher[]
  stockAdjustments   StockAdjustment[]
  assetDisposals     AssetDisposal[]

  @@index([documentType, documentId])
  @@index([status])
  @@map("workflow_instances")
}

model WorkflowInstanceStep {
  id               String     @id @default(cuid())
  instanceId       String
  stepNumber       Int
  stepName         String
  assignedUserId   String?
  assignedRoleId   String?
  status           StepStatus @default(PENDING)
  startedAt        DateTime?
  completedAt      DateTime?
  dueAt            DateTime?
  action           String?
  comment          String?
  digitalSignatureId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  instance        WorkflowInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  digitalSignature DigitalSignature? @relation(fields: [digitalSignatureId], references: [id])
  actions         WorkflowActionLog[]
  escalations     WorkflowEscalation[]

  @@index([instanceId, status])
  @@map("workflow_instance_steps")
}

model WorkflowActionLog {
  id               String         @id @default(cuid())
  instanceId       String
  instanceStepId   String?
  actorId          String
  action           WorkflowAction
  comment          String?
  actionAt         DateTime       @default(now())
  digitalSignatureId String?

  instance        WorkflowInstance      @relation(fields: [instanceId], references: [id])
  instanceStep    WorkflowInstanceStep? @relation(fields: [instanceStepId], references: [id])
  actor           User                  @relation(fields: [actorId], references: [id])
  digitalSignature DigitalSignature?    @relation(fields: [digitalSignatureId], references: [id])

  @@index([instanceId])
  @@index([actorId])
  @@map("workflow_action_logs")
}

model DigitalSignature {
  id                String   @id @default(cuid())
  userId            String
  documentType      String
  documentId        String
  action            String
  ipAddress         String
  userAgent         String
  deviceFingerprint String?
  signedAt          DateTime @default(now())
  certificate       String?
  createdAt         DateTime @default(now())

  user              User                    @relation(fields: [userId], references: [id])
  workflowSteps     WorkflowInstanceStep[]
  workflowActions   WorkflowActionLog[]

  @@index([userId, documentId])
  @@index([documentType, documentId])
  @@map("digital_signatures")
}

model WorkflowDelegate {
  id           String    @id @default(cuid())
  fromUserId   String
  toUserId     String
  documentType String?
  startDate    DateTime
  endDate      DateTime
  reason       String
  isActive     Boolean   @default(true)
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([fromUserId, isActive])
  @@index([endDate])
  @@map("workflow_delegates")
}

model WorkflowEscalation {
  id                    String    @id @default(cuid())
  instanceStepId        String
  instanceId            String
  escalatedFromUserId   String?
  escalatedToUserId     String
  reason                String
  escalatedAt           DateTime  @default(now())
  resolvedAt            DateTime?
  isResolved            Boolean   @default(false)
  createdAt             DateTime  @default(now())

  instanceStep WorkflowInstanceStep @relation(fields: [instanceStepId], references: [id])
  instance     WorkflowInstance     @relation(fields: [instanceId], references: [id])

  @@index([instanceStepId])
  @@map("workflow_escalations")
}

// ============================================================
// DOMAIN 7: INVENTORY (7 tables)
// ============================================================

model Warehouse {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  address     String?
  managerId   String?
  isActive    Boolean   @default(true)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  locations     WarehouseLocation[]
  inventoryItems InventoryItem[]
  stockMovements StockMovement[]
  adjustments   StockAdjustment[]
  goodsReceipts GoodsReceipt[]

  @@map("warehouses")
}

model InventoryCategory {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  parentId    String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent   InventoryCategory?  @relation("InventoryCategoryHierarchy", fields: [parentId], references: [id])
  children InventoryCategory[] @relation("InventoryCategoryHierarchy")
  items    InventoryItem[]

  @@map("inventory_categories")
}

model InventoryItem {
  id           String      @id @default(cuid())
  sku          String      @unique
  name         String
  description  String?
  categoryId   String?
  unit         String
  reorderLevel Decimal     @default(0) @db.Decimal(10, 3)
  currentStock Decimal     @default(0) @db.Decimal(10, 3)
  unitCost     Decimal     @default(0) @db.Decimal(20, 4)
  totalValue   Decimal     @default(0) @db.Decimal(20, 4)
  warehouseId  String?
  locationCode String?
  barcodeType  BarcodeType @default(NONE)
  barcodeValue String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  category  InventoryCategory? @relation(fields: [categoryId], references: [id])
  warehouse Warehouse?         @relation(fields: [warehouseId], references: [id])
  movements StockMovement[]
  batches   InventoryBatch[]

  @@index([categoryId])
  @@index([warehouseId, isActive])
  @@map("inventory_items")
}

model StockMovement {
  id             String       @id @default(cuid())
  itemId         String
  warehouseId    String
  movementType   MovementType
  quantity       Decimal      @db.Decimal(10, 3)
  unitCost       Decimal      @db.Decimal(20, 4)
  totalCost      Decimal      @db.Decimal(20, 4)
  balanceAfter   Decimal      @db.Decimal(10, 3)
  reference      String?
  referenceId    String?
  referenceType  String?
  grantId        String?
  notes          String?
  createdById    String?
  createdAt      DateTime     @default(now())

  item      InventoryItem @relation(fields: [itemId], references: [id])
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  grant     Grant?        @relation(fields: [grantId], references: [id])

  @@index([itemId, createdAt])
  @@index([warehouseId])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

model StockAdjustment {
  id                 String         @id @default(cuid())
  serialNumber       String         @unique
  warehouseId        String
  adjustmentDate     DateTime
  reason             String
  status             DocumentStatus @default(DRAFT)
  workflowInstanceId String?
  createdById        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  workflow  WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@index([warehouseId, status])
  @@map("stock_adjustments")
}

model InventoryBatch {
  id          String    @id @default(cuid())
  itemId      String
  batchNumber String    @unique
  expiryDate  DateTime?
  quantity    Decimal   @db.Decimal(10, 3)
  receivedDate DateTime
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  item InventoryItem @relation(fields: [itemId], references: [id])

  @@index([itemId])
  @@index([expiryDate])
  @@map("inventory_batches")
}

model WarehouseLocation {
  id          String   @id @default(cuid())
  warehouseId String
  code        String
  name        String
  row         String?
  shelf       String?
  bin         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, code])
  @@map("warehouse_locations")
}

// ============================================================
// DOMAIN 8: FIXED ASSETS (8 tables)
// ============================================================

model AssetCategory {
  id                    String             @id @default(cuid())
  name                  String
  code                  String             @unique
  parentId              String?
  depreciationMethod    DepreciationMethod @default(STRAIGHT_LINE)
  usefulLifeYears       Int                @default(5)
  residualValuePercent  Decimal            @default(0) @db.Decimal(5, 2)
  glAccountId           String?
  depreciationGlAccountId String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  parent           AssetCategory?  @relation("AssetCategoryHierarchy", fields: [parentId], references: [id])
  children         AssetCategory[] @relation("AssetCategoryHierarchy")
  glAccount        ChartOfAccount? @relation("AssetGLAccount", fields: [glAccountId], references: [id])
  depreciationGlAccount ChartOfAccount? @relation("AssetDeprecGLAccount", fields: [depreciationGlAccountId], references: [id])
  assets           FixedAsset[]

  @@map("asset_categories")
}

model FixedAsset {
  id                   String             @id @default(cuid())
  serialNumber         String             @unique
  assetCode            String             @unique
  name                 String
  description          String?
  categoryId           String
  grantId              String?
  purchaseDate         DateTime
  purchasePrice        Decimal            @db.Decimal(20, 4)
  currency             String             @default("USD")
  currentBookValue     Decimal            @db.Decimal(20, 4)
  depreciationMethod   DepreciationMethod @default(STRAIGHT_LINE)
  usefulLifeYears      Int
  residualValue        Decimal            @default(0) @db.Decimal(20, 4)
  depreciationStartDate DateTime
  lastDepreciationDate DateTime?
  warehouseId          String?
  locationCode         String?
  barcodeType          BarcodeType        @default(NONE)
  barcodeValue         String?
  status               AssetStatus        @default(ACTIVE)
  purchaseOrderId      String?
  createdById          String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?

  category        AssetCategory          @relation(fields: [categoryId], references: [id])
  grant           Grant?                 @relation(fields: [grantId], references: [id])
  purchaseOrder   PurchaseOrder?         @relation(fields: [purchaseOrderId], references: [id])
  assignments     AssetAssignment[]
  maintenance     AssetMaintenance[]
  depSchedules    AssetDepreciationSchedule[]
  depEntries      AssetDepreciationEntry[]
  disposals       AssetDisposal[]
  verifications   AssetVerification[]

  @@index([categoryId, status])
  @@index([grantId])
  @@map("fixed_assets")
}

model AssetAssignment {
  id             String         @id @default(cuid())
  assetId        String
  assignedToId   String
  departmentId   String?
  assignedDate   DateTime
  returnDate     DateTime?
  condition      AssetCondition @default(GOOD)
  notes          String?
  assignedById   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  asset      FixedAsset @relation(fields: [assetId], references: [id])
  assignedTo User       @relation("AssetAssignedTo", fields: [assignedToId], references: [id])
  assignedBy User?      @relation("AssetAssignedBy", fields: [assignedById], references: [id])

  @@index([assetId])
  @@index([assignedToId])
  @@map("asset_assignments")
}

model AssetMaintenance {
  id              String          @id @default(cuid())
  assetId         String
  maintenanceType MaintenanceType
  scheduledDate   DateTime
  completedDate   DateTime?
  description     String
  cost            Decimal         @default(0) @db.Decimal(20, 4)
  vendorId        String?
  status          String          @default("SCHEDULED")
  performedBy     String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  asset  FixedAsset @relation(fields: [assetId], references: [id])
  vendor Vendor?    @relation(fields: [vendorId], references: [id])

  @@index([assetId, status])
  @@index([scheduledDate])
  @@map("asset_maintenance")
}

model AssetDepreciationSchedule {
  id                      String    @id @default(cuid())
  assetId                 String
  period                  DateTime
  depreciationAmount      Decimal   @db.Decimal(20, 4)
  accumulatedDepreciation Decimal   @db.Decimal(20, 4)
  bookValue               Decimal   @db.Decimal(20, 4)
  isPosted                Boolean   @default(false)
  journalEntryId          String?
  postedAt                DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  asset FixedAsset @relation(fields: [assetId], references: [id])

  @@index([assetId, period])
  @@map("asset_depreciation_schedules")
}

model AssetDepreciationEntry {
  id                String           @id @default(cuid())
  assetId           String
  periodId          String
  depreciationAmount Decimal         @db.Decimal(20, 4)
  bookValueBefore   Decimal          @db.Decimal(20, 4)
  bookValueAfter    Decimal          @db.Decimal(20, 4)
  journalEntryId    String?
  isPosted          Boolean          @default(false)
  createdAt         DateTime         @default(now())

  asset        FixedAsset       @relation(fields: [assetId], references: [id])
  period       AccountingPeriod @relation(fields: [periodId], references: [id])
  journalEntry JournalEntry?    @relation(fields: [journalEntryId], references: [id])

  @@index([assetId, periodId])
  @@map("asset_depreciation_entries")
}

model AssetDisposal {
  id                  String         @id @default(cuid())
  assetId             String
  disposalDate        DateTime
  disposalMethod      DisposalMethod
  saleAmount          Decimal        @default(0) @db.Decimal(20, 4)
  bookValueAtDisposal Decimal        @db.Decimal(20, 4)
  gainLoss            Decimal        @db.Decimal(20, 4)
  reason              String
  approvedById        String?
  journalEntryId      String?
  status              DocumentStatus @default(DRAFT)
  workflowInstanceId  String?
  createdById         String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  asset        FixedAsset       @relation(fields: [assetId], references: [id])
  journalEntry JournalEntry?    @relation(fields: [journalEntryId], references: [id])
  workflow     WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@index([assetId, status])
  @@map("asset_disposals")
}

model AssetVerification {
  id               String         @id @default(cuid())
  assetId          String
  verificationDate DateTime
  verifiedById     String
  condition        AssetCondition
  location         String?
  notes            String?
  photoUrl         String?
  createdAt        DateTime       @default(now())

  asset      FixedAsset @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@map("asset_verifications")
}

// ============================================================
// DOMAIN 9: COLLABORATION (6 tables)
// ============================================================

model DocumentAttachment {
  id           String    @id @default(cuid())
  documentType String
  documentId   String
  fileName     String
  originalName String
  fileSize     Int
  mimeType     String
  fileUrl      String
  storageKey   String
  uploadedById String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([documentType, documentId])
  @@index([uploadedById])
  @@map("document_attachments")
}

model DocumentVersion {
  id             String   @id @default(cuid())
  documentType   String
  documentId     String
  versionNumber  Int
  changesSummary String?
  snapshotData   Json
  createdById    String?
  createdAt      DateTime @default(now())

  @@index([documentType, documentId, versionNumber])
  @@map("document_versions")
}

model Comment {
  id           String    @id @default(cuid())
  documentType String
  documentId   String
  parentId     String?
  content      String
  isInternal   Boolean   @default(false)
  isResolved   Boolean   @default(false)
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  createdBy User            @relation(fields: [createdById], references: [id])
  parent    Comment?        @relation("CommentThread", fields: [parentId], references: [id])
  replies   Comment[]       @relation("CommentThread")
  mentions  CommentMention[]

  @@index([documentType, documentId])
  @@index([createdById])
  @@map("comments")
}

model CommentMention {
  id              String   @id @default(cuid())
  commentId       String
  mentionedUserId String
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([mentionedUserId, isRead])
  @@map("comment_mentions")
}

model Notification {
  id           String              @id @default(cuid())
  userId       String
  type         NotificationType    @default(INFO)
  title        String
  message      String
  actionUrl    String?
  documentType String?
  documentId   String?
  isRead       Boolean             @default(false)
  readAt       DateTime?
  channel      NotificationChannel @default(IN_APP)
  sentAt       DateTime?
  createdAt    DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([documentType, documentId])
  @@map("notifications")
}

model NotificationPreference {
  id          String   @id @default(cuid())
  userId      String
  module      String
  eventType   String
  emailEnabled Boolean @default(true)
  inAppEnabled Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, module, eventType])
  @@index([userId])
  @@map("notification_preferences")
}

// ============================================================
// DOMAIN 10: AUDIT (1 table)
// ============================================================

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  userEmail   String?
  action      AuditAction
  module      String
  resource    String
  resourceId  String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  sessionId   String?
  requestId   String?
  duration    Int?
  createdAt   DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([module, resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
