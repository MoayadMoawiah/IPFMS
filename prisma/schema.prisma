// ============================================================
// G-GPFMS Prisma Schema — PostgreSQL 16
// Gaderon Grants, Procurement & Financial Management ERP
// 85 Tables across 10 domains
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

// Seed configuration
// Run: cd backend && npm run prisma:seed

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum DocumentStatus {
  DRAFT
  SUBMITTED
  RETURNED
  APPROVED
  REJECTED
  CANCELLED
  CLOSED
  ARCHIVED
}

enum WorkflowAction {
  SUBMIT
  APPROVE
  REJECT
  RETURN
  DELEGATE
  ESCALATE
  COMMENT
}

enum WorkflowStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  RETURNED
  CANCELLED
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  RETURNED
  SKIPPED
  ESCALATED
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  SUBMIT
  APPROVE
  REJECT
  RETURN
  CLOSE
  EXPORT
  IMPORT
  PRINT
  DELEGATE
  CONFIGURE
  RESTORE
  MANAGE_BUDGET
  BLACKLIST
  ISSUE
  EVALUATE
