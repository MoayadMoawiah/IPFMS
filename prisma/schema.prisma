// ============================================================
// DOMAIN 1: CORE (9 tables)
// ============================================================

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  shortName            String
  logo                 String?
  address              String?
  city                 String?
  country              String   @default("Sudan")
  phone                String?
  email                String?
  website              String?
  taxNumber            String?
  registrationNumber   String?
  baseCurrency         String   @default("USD")
  secondaryCurrency    String   @default("SDG")
  fiscalYearStartMonth Int      @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  departments Department[]
  users       User[]

  @@map("organizations")
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  parentId       String?
  name           String
  code           String       @unique
  description    String?
  headUserId     String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id])
  parent       Department?   @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children     Department[]  @relation("DepartmentHierarchy")
  users        User[]
  head         User?         @relation("DepartmentHead", fields: [headUserId], references: [id])

  @@index([organizationId])
  @@index([parentId])
  @@map("departments")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  firstName        String
  lastName         String
  arabicName       String?
  phone            String?
  avatar           String?
  organizationId   String?
  departmentId     String?
  isActive         Boolean   @default(true)
  isEmailVerified  Boolean   @default(false)
  lastLoginAt      DateTime?
  lastLoginIp      String?
  refreshTokenHash String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  organization     Organization?      @relation(fields: [organizationId], references: [id])
  department       Department?        @relation(fields: [departmentId], references: [id])
  managedDept      Department[]       @relation("DepartmentHead")
  roles            UserRole[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  comments         Comment[]
  digitalSigs      DigitalSignature[]
  uploadedFiles    DocumentAttachment[]
  grantAmendments  GrantAmendment[]   @relation("GrantAmendmentCreator")
  approvedAmends   GrantAmendment[]   @relation("GrantAmendmentApprover")
  grants           Grant[]            @relation("GrantManager")
  coordGrants      Grant[]            @relation("GrantCoordinator")
  createdGrants    Grant[]            @relation("GrantCreator")
  journalEntries        JournalEntry[]
  workflowActions       WorkflowActionLog[]
  projectStaff          ProjectStaff[]
  responsibleActivities Activity[]         @relation("ActivityResponsible")
  managedProjects       Project[]          @relation("ProjectManager")
  assetAssignments      AssetAssignment[]  @relation("AssetAssignedTo")
  assetAssignedBy       AssetAssignment[]  @relation("AssetAssignedBy")
  settings              Setting[]
  purchaseRequisitions  PurchaseRequisition[]
  goodsReceipts         GoodsReceipt[]

  @@index([email])
  @@index([organizationId])
  @@index([departmentId])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String?
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]
  workflowSteps   WorkflowStep[]   @relation("ApproverRole")
  escalationSteps WorkflowStep[]   @relation("EscalationRole")

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  module      PermissionModule
  action      PermissionAction
  resource    String?
  description String?
  createdAt   DateTime         @default(now())

  rolePermissions RolePermission[]

  @@unique([module, action, resource])
  @@index([module])
  @@map("permissions")
}

model UserRole {
  userId    String
  roleId    String
  grantedBy String?
  grantedAt DateTime @default(now())

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  isPublic    Boolean  @default(false)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation(fields: [updatedById], references: [id])

  @@map("settings")
}

model SerialSequence {
  id         String              @id @default(cuid())
  grantCode  String
  docType    ProcurementDocType
  lastNumber Int                 @default(0)
  prefix     String?
  format     String              @default("{grantCode}-{docType}-{number:4}")
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([grantCode, docType])
  @@map("serial_sequences")
}

// ============================================================
// DOMAIN 2: GRANTS (9 tables)
// ============================================================

model Donor {
  id           String    @id @default(cuid())
  name         String
  code         String    @unique
  country      String?
  donorType    DonorType @default(OTHER)
  contactName  String?
  contactEmail String?
  contactPhone String?
  address      String?
  website      String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  grants Grant[]

  @@index([code])
  @@map("donors")
}

model Currency {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  symbol    String
  isBase    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromRates ExchangeRate[] @relation("FromCurrency")
  toRates   ExchangeRate[] @relation("ToCurrency")

  @@map("currencies")
}

model ExchangeRate {
  id               String             @id @default(cuid())
  fromCurrencyId   String
  toCurrencyId     String
  rate             Decimal            @db.Decimal(20, 8)
  effectiveDate    DateTime
  source           ExchangeRateSource @default(MANUAL)
  grantId          String?
  createdById      String?
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  fromCurrency Currency @relation("FromCurrency", fields: [fromCurrencyId], references: [id])
  toCurrency   Currency @relation("ToCurrency", fields: [toCurrencyId], references: [id])
  grant        Grant?   @relation(fields: [grantId], references: [id])

  @@index([fromCurrencyId, toCurrencyId, effectiveDate])
  @@index([grantId])
  @@map("exchange_rates")
}

model FiscalYear {
  id         String           @id @default(cuid())
  name       String
  startDate  DateTime
  endDate    DateTime
  status     FiscalYearStatus @default(OPEN)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  periods AccountingPeriod[]
  grants  Grant[]
  apps    AnnualProcurementPlan[]

  @@map("fiscal_years")
}

model AccountingPeriod {
  id           String       @id @default(cuid())
  fiscalYearId String
  name         String
  periodNumber Int
  startDate    DateTime
  endDate      DateTime
  status       PeriodStatus @default(OPEN)
  closedById   String?
  closedAt     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  fiscalYear     FiscalYear     @relation(fields: [fiscalYearId], references: [id])
  journalEntries JournalEntry[]
  reconciliations BankReconciliation[]
  depreciationEntries AssetDepreciationEntry[]

  @@index([fiscalYearId, status])
  @@map("accounting_periods")
}

model Grant {
  id                   String      @id @default(cuid())
  code                 String      @unique
  name                 String
  donorId              String
  fiscalYearId         String?
  currency             String      @default("USD")
  totalBudget          Decimal     @db.Decimal(20, 4)
  committedAmount      Decimal     @default(0) @db.Decimal(20, 4)
  spentAmount          Decimal     @default(0) @db.Decimal(20, 4)
  startDate            DateTime
  endDate              DateTime
  signedDate           DateTime?
  status               GrantStatus @default(DRAFT)
  description          String?
  objectives           String?
  conditions           String?
  coverageArea         String?
  targetBeneficiaries  Int?
  reportingRequirements String?
  grantManagerId       String?
  projectCoordinatorId String?
  createdById          String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  deletedAt            DateTime?

  donor              Donor              @relation(fields: [donorId], references: [id])
  fiscalYear         FiscalYear?        @relation(fields: [fiscalYearId], references: [id])
  grantManager       User?              @relation("GrantManager", fields: [grantManagerId], references: [id])
  coordinator        User?              @relation("GrantCoordinator", fields: [projectCoordinatorId], references: [id])
  createdBy          User?              @relation("GrantCreator", fields: [createdById], references: [id])
  budgetLines        GrantBudgetLine[]
  amendments         GrantAmendment[]
  extensions         GrantExtension[]
  exchangeRates      ExchangeRate[]
  projects           Project[]
  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders     PurchaseOrder[]
  annualPlans        AnnualProcurementPlan[]
  rfqs               Rfq[]
  paymentVouchers    PaymentVoucher[]
  paymentRequests    PaymentRequest[]
  journalEntries     JournalEntry[]
  fixedAssets        FixedAsset[]
  stockMovements     StockMovement[]
  contracts          Contract[]
  vendorInvoices     VendorInvoice[]
  goodsReceipts      GoodsReceipt[]

  @@index([status, deletedAt])
  @@index([donorId])
  @@index([code])
  @@map("grants")
}

model GrantBudgetLine {
  id              String         @id @default(cuid())
  grantId         String
  activityId      String?
  code            String
  description     String
  category        BudgetCategory @default(OTHER)
  totalBudget     Decimal        @db.Decimal(20, 4)
  committedAmount Decimal        @default(0) @db.Decimal(20, 4)
  spentAmount     Decimal        @default(0) @db.Decimal(20, 4)
  currency        String         @default("USD")
  notes           String?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  grant          Grant           @relation(fields: [grantId], references: [id])
  activity       Activity?       @relation("ActivityBudgetLine", fields: [activityId], references: [id])
  prItems        PrItem[]
  poItems        PoItem[]
  activityLines  ActivityBudgetLine[]
  journalLines   JournalLine[]

  @@index([grantId])
  @@index([activityId])
  @@map("grant_budget_lines")
}

model GrantAmendment {
  id                 String         @id @default(cuid())
  grantId            String
  amendmentNumber    Int
  title              String
  description        String
  amendmentType      AmendmentType
  effectiveDate      DateTime
  previousValue      Json?
  newValue           Json?
  status             DocumentStatus @default(DRAFT)
  workflowInstanceId String?
  createdById        String?
  approvedById       String?
  approvedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  grant      Grant              @relation(fields: [grantId], references: [id])
  createdBy  User?              @relation("GrantAmendmentCreator", fields: [createdById], references: [id])
  approvedBy User?              @relation("GrantAmendmentApprover", fields: [approvedById], references: [id])
  workflow   WorkflowInstance?  @relation(fields: [workflowInstanceId], references: [id])

  @@index([grantId])
  @@map("grant_amendments")
}

model GrantExtension {
  id                 String         @id @default(cuid())
  grantId            String
  extensionNumber    Int
  previousEndDate    DateTime
  newEndDate         DateTime
  reason             String
  status             DocumentStatus @default(DRAFT)
  workflowInstanceId String?
  createdById        String?
  approvedById       String?
  approvedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  grant    Grant             @relation(fields: [grantId], references: [id])
  workflow WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@index([grantId])
  @@map("grant_extensions")
}

// ============================================================
// DOMAIN 3: PROJECTS (5 tables)
// ============================================================

model Project {
  id             String        @id @default(cuid())
  grantId        String
  code           String        @unique
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime
  budget           Decimal   @db.Decimal(20, 4)
  committedBudget  Decimal   @default(0) @db.Decimal(20, 4)
  spentBudget      Decimal   @default(0) @db.Decimal(20, 4)
  targetBeneficiaries Int?
  progressPercent  Decimal   @default(0) @db.Decimal(5, 2)
  status           ProjectStatus @default(PLANNING)
  projectManagerId String?
  createdById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  grant      Grant             @relation(fields: [grantId], references: [id])
  projectManager User?           @relation("ProjectManager", fields: [projectManagerId], references: [id])
  milestones ProjectMilestone[]
  activities Activity[]
  staff      ProjectStaff[]

  @@unique([grantId])
  @@index([grantId, status])
  @@map("projects")
}

model ProjectMilestone {
  id              String          @id @default(cuid())
  projectId       String
  title           String
  description     String?
  quarter         Quarter
  dueDate         DateTime
  deliverables    Json?
  budget          Decimal         @db.Decimal(20, 4)
  paymentPercent  Decimal         @default(0) @db.Decimal(5, 2)
  status          MilestoneStatus @default(PENDING)
  completedAt     DateTime?
  approvedById    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, status])
  @@map("project_milestones")
}

model Activity {
  id               String         @id @default(cuid())
  projectId        String
  code             String
  name             String
  description      String?
  startDate        DateTime
  endDate          DateTime
  plannedBudget    Decimal        @db.Decimal(20, 4)
  actualSpent      Decimal        @default(0) @db.Decimal(20, 4)
  progressPercent  Decimal        @default(0) @db.Decimal(5, 2)
  status           ActivityStatus @default(PLANNING)
  responsibleUserId String?
  createdById      String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  project         Project              @relation(fields: [projectId], references: [id])
  responsibleUser User?                @relation("ActivityResponsible", fields: [responsibleUserId], references: [id])
  budgetLines     ActivityBudgetLine[]
  grantBudgetLine GrantBudgetLine[]    @relation("ActivityBudgetLine")
  appItems        AppItem[]
  prItems         PurchaseRequisition[]

  @@unique([projectId, code])
  @@index([projectId, status])
  @@map("activities")
}

model ActivityBudgetLine {
  id              String  @id @default(cuid())
  activityId      String
  budgetLineId    String
  allocatedAmount Decimal @db.Decimal(20, 4)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  activity   Activity        @relation(fields: [activityId], references: [id])
  budgetLine GrantBudgetLine @relation(fields: [budgetLineId], references: [id])

  @@unique([activityId, budgetLineId])
  @@map("activity_budget_lines")
}

model ProjectStaff {
  id        String    @id @default(cuid())
  projectId String
  userId    String
  role      String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@map("project_staff")
}

// ============================================================
// DOMAIN 4: PROCUREMENT (18 tables)
// ============================================================

model ProcurementMethod {
  id                String   @id @default(cuid())
  name              String   @unique
  code              String   @unique
  description       String?
  minThreshold      Decimal  @default(0) @db.Decimal(20, 4)
  maxThreshold      Decimal? @db.Decimal(20, 4)
  minVendors        Int      @default(1)
  requiresCommittee Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  appItems             AppItem[]
  purchaseRequisitions PurchaseRequisition[]
  rfqs                 Rfq[]

  @@map("procurement_methods")
}

model AnnualProcurementPlan {
  id                 String         @id @default(cuid())
  serialNumber       String         @unique
  grantId            String
  fiscalYearId       String
  title              String
  description        String?
  totalBudget        Decimal        @db.Decimal(20, 4)
  status             DocumentStatus @default(DRAFT)
  workflowInstanceId String?
  createdById        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  grant      Grant             @relation(fields: [grantId], references: [id])
  fiscalYear FiscalYear        @relation(fields: [fiscalYearId], references: [id])
  workflow   WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  items      AppItem[]

  @@index([grantId, status])
  @@index([fiscalYearId])
  @@map("annual_procurement_plans")
}

model AppItem {
  id                  String    @id @default(cuid())
  appId               String
  activityId          String?
