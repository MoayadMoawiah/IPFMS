# ============================================================
# G-GPFMS Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://gpfms_user:your_password@localhost:5432/gpfms_db"
# For test environment:
# DATABASE_URL="postgresql://gpfms_user:your_password@localhost:5432/gpfms_test"

# ── Authentication ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_THIS_TO_A_256_BIT_RANDOM_SECRET"
JWT_REFRESH_SECRET="CHANGE_THIS_TO_A_DIFFERENT_256_BIT_RANDOM_SECRET"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# With password: REDIS_URL="redis://:your_password@localhost:6379"
REDIS_TTL=300

# ── MinIO (File Storage) ────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="gpfms-documents"
MINIO_PDF_BUCKET="gpfms-pdfs"
MINIO_REGION="us-east-1"

# ── SMTP (Email) ────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="noreply@gaderon.org"
SMTP_PASS="your_email_app_password"
SMTP_FROM="Gaderon ERP <noreply@gaderon.org>"

# ── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_APP_NAME="G-GPFMS"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_ORG_NAME="Gaderon Organization for Development"

# ── Swagger API Docs ────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_TITLE="G-GPFMS API"
SWAGGER_DESCRIPTION="Gaderon Grants, Procurement & Financial Management ERP API"
SWAGGER_VERSION="1.0.0"

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_TTL=60
AUTH_RATE_LIMIT_MAX=10

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:3000"
# Production: CORS_ORIGIN="https://erp.gaderon.org"

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL="debug"
# Production: LOG_LEVEL="warn"

# ── PDF Generation ──────────────────────────────────────────
PDF_TEMP_DIR="/tmp/gpfms-pdfs"

# ── BullMQ Queue Names ───────────────────────────────────────
QUEUE_EMAIL="gpfms-email"
QUEUE_PDF="gpfms-pdf"
QUEUE_NOTIFICATIONS="gpfms-notifications"
QUEUE_ESCALATIONS="gpfms-escalations"

# ── Organization Defaults ────────────────────────────────────
DEFAULT_CURRENCY="USD"
DEFAULT_SECONDARY_CURRENCY="SDG"
DEFAULT_TIMEZONE="Africa/Khartoum"
DEFAULT_DATE_FORMAT="DD/MM/YYYY"
DEFAULT_FISCAL_YEAR_START="01"
# Month number (01=January)

# ── Security ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
SESSION_SECRET="CHANGE_THIS_TO_RANDOM_SECRET"
COOKIE_DOMAIN="localhost"
COOKIE_SECURE=false
# Production: COOKIE_SECURE=true

# ── Seed Data ───────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@gaderon.org"
SEED_ADMIN_PASSWORD="Admin@2026!"
SEED_ADMIN_FIRST_NAME="System"
SEED_ADMIN_LAST_NAME="Administrator"
